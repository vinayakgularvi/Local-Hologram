# Copy to .env and adjust. Loaded from repo root and backend/ when starting uvicorn.

LIPSYNC_FILE_API_URL=http://10.29.145.124:8000/lipsync/file
LIPSYNC_CHECKPOINT_PATH=checkpoints/checkpoints/Wav2Lip-SD-GAN.pt
LIPSYNC_FPS=25
LIPSYNC_FACE_DET_BATCH_SIZE=16
LIPSYNC_WAV2LIP_BATCH_SIZE=128
LIPSYNC_PAD_TOP=0
LIPSYNC_PAD_BOTTOM=10
LIPSYNC_PAD_LEFT=0
LIPSYNC_PAD_RIGHT=0
LIPSYNC_CROP_TOP=0
LIPSYNC_CROP_BOTTOM=-1
LIPSYNC_CROP_LEFT=0
LIPSYNC_CROP_RIGHT=-1
LIPSYNC_BOX_TOP=-1
LIPSYNC_BOX_BOTTOM=-1
LIPSYNC_BOX_LEFT=-1
LIPSYNC_BOX_RIGHT=-1
LIPSYNC_RESIZE_FACTOR=1
LIPSYNC_ROTATE=false
LIPSYNC_NOSMOOTH=false

# Speed / realtime (defaults favor one Gradio call = fastest)
# LIPSYNC_REALTIME=1           # lip-sync segments while Ollama streams (recommended)
# LIPSYNC_USE_CHUNKS=0         # 1/true = batch chunk mode on full wav (slow). OR a number >1 = realtime target segment seconds
# LIPSYNC_RT_TARGET_SEC=4      # if USE_CHUNKS is not a number, this sets realtime segment size (seconds-ish via char cap)
# LIPSYNC_RT_MIN_CHARS=16
# LIPSYNC_CHUNK_SEC=6
# LIPSYNC_AUTO_SINGLE_BELOW_SEC=60
# LIPSYNC_CHUNK_PARALLEL=1

OLLAMA_BASE=http://10.29.145.124:8000
OLLAMA_MODEL=AFM-4.5B-Q4_K_M.gguf
# MODEL_API_STYLE=auto           # auto|openai|ollama (use openai for /v1/chat/completions servers)

# LLM provider for voice turns, RAG answers, and /api/lipsync* (default: local = Ollama / compatible server above)
# LLM_PROVIDER=local             # local | openai | anthropic | google
# OpenAI (https://api.openai.com/v1/chat/completions when base is default)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini
# Anthropic Messages API (https://api.anthropic.com/v1/messages)
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Google Gemini (Generative Language API — streamGenerateContent + alt=sse)
# GOOGLE_API_KEY=
# Or: GEMINI_API_KEY=            # alias read by the server if GOOGLE_API_KEY is unset
# GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GOOGLE_GEMINI_MODEL=gemini-2.0-flash
# VOICE_MAX_TOKENS=96            # lower is faster; tune 48-128 for short avatar replies
# VITE_VOICE_SILENCE_MS=550      # auto-stop mic after silence (frontend)
# VITE_VOICE_FINAL_STOP_MS=220   # stop quickly after first final speech result
# VITE_WEBRTC_ICE_GATHER_TIMEOUT_MS=250  # send offer faster (ms)
# VITE_WEBRTC_STUN_URL=stun:stun.l.google.com:19302
# Optional system-style line for POST /api/voice-turn (mic → Ollama → LiveTalking)
# VOICE_OLLAMA_INSTRUCTION=You are a concise hologram assistant...

# LiveTalking-style WebRTC: FastAPI forwards POST /offer, /human, /record to this origin
# WEBRTC_SIGNALING_BASE=http://127.0.0.1:8010
# Avatar/voice-clone Gradio app base (used by /api/avatar/* endpoints)
# AVATAR_API_BASE=http://10.29.145.124:9000
# AVATAR_SAMPLE_TEXT=Read this script while recording your voice sample.

# ChromaDB RAG (Avatar Studio — PDF / DOCX / TXT ingest). Data: backend/data/chroma/
# RAG_MAX_UPLOAD_MB=25
# RAG_CHUNK_SIZE=900
# RAG_CHUNK_OVERLAP=120
# Optional: wipe entire vector store (POST /api/rag/reset with body {"secret":"..."})
# RAG_RESET_SECRET=

# RAG in live voice pipeline (POST /api/voice-turn): Chroma retrieval → Ollama prompt
# VOICE_RAG_ENABLED=1
# VOICE_RAG_N_RESULTS=6
# VOICE_RAG_MAX_CONTEXT_CHARS=3500

# Microsoft SharePoint → Chroma (Graph API, application permissions)
# Register an app in Azure Entra ID; add Microsoft Graph application permissions (admin consent), e.g. Sites.Read.All
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/YourSite
# Optional: folder under the default document library root (use "Shared Documents/Subfolder" style paths)
# SHAREPOINT_FOLDER_PATH=
# Optional: use a specific drive ID instead of the site's default library
# SHAREPOINT_DRIVE_ID=
# SHAREPOINT_MAX_FILES=80
# SHAREPOINT_MAX_DEPTH=6
# SHAREPOINT_MAX_BYTES=26214400
# SHAREPOINT_ALLOWED_SUFFIXES=.pdf,.docx,.txt,.md
# Continuous background sync into Chroma (same as manual sync; uses a lock so runs never overlap)
# SHAREPOINT_LIVE_SYNC=1
# SHAREPOINT_SYNC_INTERVAL_SEC=90

# Google Drive → Chroma (Drive API v3, service account)
# Enable Drive API in GCP; create a service account and download JSON key.
# Share your target folder with the service account email (Viewer is enough).
# GOOGLE_DRIVE_CREDENTIALS_PATH=backend/secrets/gdrive-sa.json
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_DRIVE_MAX_FILES=80
# GOOGLE_DRIVE_MAX_DEPTH=6
# GOOGLE_DRIVE_MAX_BYTES=26214400
# GOOGLE_DRIVE_ALLOWED_SUFFIXES=.pdf,.docx,.txt,.md
# GOOGLE_DRIVE_LIVE_SYNC=1
# GOOGLE_DRIVE_SYNC_INTERVAL_SEC=90

# Dropbox → Chroma (files.content.read scope)
# Create a Dropbox app; for servers prefer a refresh token + app key/secret.
# DROPBOX_ACCESS_TOKEN=
# Or:
# DROPBOX_REFRESH_TOKEN=
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=
# Optional folder (default: account / app root). Example: /Handbook
# DROPBOX_FOLDER_PATH=
# DROPBOX_MAX_FILES=80
# DROPBOX_MAX_DEPTH=6
# DROPBOX_MAX_BYTES=26214400
# DROPBOX_ALLOWED_SUFFIXES=.pdf,.docx,.txt,.md
# DROPBOX_LIVE_SYNC=1
# DROPBOX_SYNC_INTERVAL_SEC=90

# Amazon S3 → Chroma (boto3)
# S3_BUCKET=
# Optional key prefix (virtual folders under this prefix are crawled)
# S3_PREFIX=
# Region if not implicit from default chain
# AWS_REGION=us-east-1
# Or rely on instance/profile credentials:
# S3_USE_DEFAULT_CREDENTIAL_CHAIN=1
# Or explicit keys (omit if using default chain):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# S3_MAX_FILES=80
# S3_MAX_DEPTH=8
# S3_MAX_BYTES=26214400
# S3_ALLOWED_SUFFIXES=.pdf,.docx,.txt,.md
# S3_LIVE_SYNC=1
# S3_SYNC_INTERVAL_SEC=90

# Azure Blob Storage → Chroma (azure-storage-blob)
# AZURE_BLOB_CONTAINER=
# AZURE_BLOB_PREFIX=
# Either a full connection string:
# AZURE_STORAGE_CONNECTION_STRING=
# Or account name + key:
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
# AZURE_BLOB_MAX_FILES=80
# AZURE_BLOB_MAX_DEPTH=8
# AZURE_BLOB_MAX_BYTES=26214400
# AZURE_BLOB_ALLOWED_SUFFIXES=.pdf,.docx,.txt,.md
# AZURE_BLOB_LIVE_SYNC=1
# AZURE_BLOB_SYNC_INTERVAL_SEC=90

# Google Cloud Storage → Chroma (google-cloud-storage)
# GCS_BUCKET=
# GCS_PREFIX=
# Service account JSON path (or standard env):
# GCS_CREDENTIALS_PATH=
# GOOGLE_APPLICATION_CREDENTIALS=
# Or workload / local gcloud ADC:
# GCS_USE_ADC=1
# GCS_MAX_FILES=80
# GCS_MAX_DEPTH=8
# GCS_MAX_BYTES=26214400
# GCS_ALLOWED_SUFFIXES=.pdf,.docx,.txt,.md
# GCS_LIVE_SYNC=1
# GCS_SYNC_INTERVAL_SEC=90

# Avatar Studio can save the above connector settings via the UI to:
# backend/data/studio_integrations.json (overrides .env until cleared). Gitignored by default.
